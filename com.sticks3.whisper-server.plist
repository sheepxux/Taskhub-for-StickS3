<?xml version="1.0" encoding="UTF-8"?>
<!--
  Keep whisper-server running (model resident in memory), restart on crash/boot.

  Install:
    1. Edit the absolute path below to match this checkout.
    2. cp com.sticks3.whisper-server.plist ~/Library/LaunchAgents/
    3. launchctl load ~/Library/LaunchAgents/com.sticks3.whisper-server.plist
  Then run transcribe.py with WHISPER_SERVER_URL=http://127.0.0.1:8080
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sticks3.whisper-server</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/path/to/Taskhub-for-StickS3/run_whisper_server.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/path/to/Taskhub-for-StickS3/whisper-server.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/Taskhub-for-StickS3/whisper-server.log</string>
</dict>
</plist>
