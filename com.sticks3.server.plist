<?xml version="1.0" encoding="UTF-8"?>
<!--
  Keep the skill HTTP server (server.py, 0.0.0.0:5577) running, restart on crash/boot.

  Install:
    cp com.sticks3.server.plist ~/Library/LaunchAgents/
    launchctl load -w ~/Library/LaunchAgents/com.sticks3.server.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sticks3.server</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/path/to/Taskhub-for-StickS3/run_server.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/path/to/Taskhub-for-StickS3/server.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/Taskhub-for-StickS3/server.log</string>
</dict>
</plist>
