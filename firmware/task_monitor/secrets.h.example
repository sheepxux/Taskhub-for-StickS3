// Copy to `secrets.h` and fill in your LAN values. secrets.h is gitignored.
#pragma once

#define WIFI_SSID       "your-wifi-ssid"
#define WIFI_PASSWORD   "your-wifi-password"

// Fallback Mac LAN address. The firmware first tries UDP discovery.
#define TASK_HUB_HOST   "192.168.1.100"
#define TASK_HUB_PORT   5577
#define TASK_HUB_DISCOVERY_PORT 5578

#define DEVICE_ID       "sticks3-task-01"
#define DEVICE_TOKEN    "dev-token"

// Battery-first default: wake every 10 minutes, fetch once, then sleep again.
// Active or attention tasks wake more often through ACTIVE_WAKE_SECONDS.
#define AUTO_WAKE_SECONDS 600

// Power profile. Lower these if charging still feels slow.
#define DISPLAY_BRIGHTNESS 32
#define LOW_BATTERY_BRIGHTNESS 16
#define LOW_BATTERY_THRESHOLD_PCT 30
// Wake cadence while tasks are active/attention/wait. 60s caps how long a
// freshly-appeared WAIT can stay unnoticed; raise for more battery life.
#define ACTIVE_WAKE_SECONDS 60
#define LOW_BATTERY_WAKE_SECONDS 900
#define INTERACTIVE_TIMEOUT_MS 10000
#define QUIET_TIMER_TIMEOUT_MS 3000
#define POWER_SAVE_CPU_MHZ 80
#define CHARGE_CURRENT_MA 200

// Alerts fire once on status edges: WAIT wakes the screen and plays a short
// double beep; DONE plays a softer rising chime after a running turn finishes.
// Set ALERT_BEEP 0 for silent screen-only alerts, or disable either edge.
// ALERT_VIBRATION is a no-op on M5StickS3 with the current M5Unified.
// #define ALERT_ON_WAIT 1
// #define ALERT_ON_DONE 1
// #define ALERT_BEEP 1
// #define ALERT_WAIT_HZ 2400
// #define ALERT_DONE_HZ 1500
// #define ALERT_BEEP_VOLUME 150
