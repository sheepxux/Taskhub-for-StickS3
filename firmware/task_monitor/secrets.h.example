// Copy to `secrets.h` and fill in your LAN values. secrets.h is gitignored.
#pragma once

#define WIFI_SSID       "your-wifi-ssid"
#define WIFI_PASSWORD   "your-wifi-password"

// Fallback Mac LAN address. The firmware first tries UDP discovery.
#define TASK_HUB_HOST   "192.168.1.100"
#define TASK_HUB_PORT   5577
#define TASK_HUB_DISCOVERY_PORT 5578

#define DEVICE_ID       "sticks3-task-01"
#define DEVICE_TOKEN    "dev-token"

// Battery-first default: wake every 5 minutes, fetch once, then sleep again.
#define AUTO_WAKE_SECONDS 300
