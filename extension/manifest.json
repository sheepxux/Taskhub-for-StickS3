{
  "manifest_version": 3,
  "name": "TaskHub Web Bridge",
  "version": "0.1.0",
  "description": "Pushes browser AI task titles (Gemini, Lovable, Perplexity) to a local TaskHub Host so they appear on your StickS3.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "http://127.0.0.1:5577/*",
    "http://localhost:5577/*",
    "https://gemini.google.com/*",
    "https://lovable.dev/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*"
  ],
  "background": { "service_worker": "background.js" },
  "options_page": "options.html",
  "action": { "default_title": "TaskHub Web Bridge", "default_popup": "options.html" },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/common.js", "content/gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://lovable.dev/*"],
      "js": ["content/common.js", "content/lovable.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.perplexity.ai/*", "https://perplexity.ai/*"],
      "js": ["content/common.js", "content/perplexity.js"],
      "run_at": "document_idle"
    }
  ]
}
